# udev rules for OpenRGB (allow non-root access to supported devices)
# Place this file at /etc/udev/rules.d/60-openrgb.rules or deploy via your provisioning system

# Corsair devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="1b1c", MODE="0666"
# Kingston/HyperX devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="0951", MODE="0666"
# Logitech devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="046d", MODE="0666"
# Razer devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="1532", MODE="0666"
# SteelSeries devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="1038", MODE="0666"
# Cooler Master devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="2516", MODE="0666"
# ASUS devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="0b05", MODE="0666"
# MSI devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="1462", MODE="0666"
# G.Skill devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="040b", MODE="0666"
# Thermaltake devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="264a", MODE="0666"
# NZXT devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="1e71", MODE="0666"
# EVGA devices
SUBSYSTEM=="usb", ATTRS{idVendor}=="3842", MODE="0666"
# Generic fallback for HID devices (optional, may be too broad)
#SUBSYSTEM=="hidraw", MODE="0666"

# Reload udev rules after copying:
# sudo udevadm control --reload-rules && sudo udevadm trigger
