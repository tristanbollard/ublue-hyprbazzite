{
	"custom/file_manager": {
		"format": "󰉋",
		"on-click": "thunar",
		"tooltip": true,
		"tooltip-format": "File Manager",
	},
	"custom/tty": {
		"format": "󰆍",
		"on-click": "kitty",
		"tooltip": true,
		"tooltip-format": "Launch Terminal",
	},
	"custom/browser": {
		"format": "󰖟",
		"on-click": "flatpak run io.github.zen_browser.zen",
		"tooltip": true,
		"tooltip-format": "Launch Browser",
	},
	"custom/lock": {
		"format": "󰌾",
		"on-click": "hyprlock",
		"tooltip": true,
		"tooltip-format": "Lock Screen",
	},
	"custom/menu": {
		"format": "󰍜",
		"on-click": "wofi --show drun --conf /etc/wofi/config --style /etc/wofi/style.css",
		"tooltip": true,
		"tooltip-format": "App Launcher",
	},
	"custom/power": {
		"format": "⏻",
		"on-click": "/etc/hypr/scripts/power-menu.sh",
		"tooltip": true,
		"tooltip-format": "Power Menu",
	},
	"custom/keyboard": {
		"format": "󰌌",
		"on-click": "/etc/hypr/scripts/waybar-osk-click.sh",
		"tooltip": true,
		"tooltip-format": "On-screen keyboard\nClick: Toggle open / close"
	},
	"custom/headset-battery": {
		"format": "󰠇 {}%",
		"exec": "/etc/hypr/scripts/TritonCtl.sh LogiBattery",
		"interval": 5,
		"on-click": "solaar",
		"return-type": "integer"
	},
	"custom/quit": {
		"format": "󰗼",
		"on-click": "hyprctl dispatch exit",
		"tooltip": true,
		"tooltip-format": "Exit Hyprland",
	},
	"custom/notification": {
		"tooltip": false,
		"format": "{icon}",
		"format-icons": {
			"notification": "<span foreground='#ff5555'><sup></sup></span>",
			"none": "",
			"dnd-notification": "<span foreground='#ff5555'><sup></sup></span>",
			"dnd-none": "",
			"inhibited-notification": "<span foreground='#ff5555'><sup></sup></span>",
			"inhibited-none": "",
			"dnd-inhibited-notification": "<span foreground='#ff5555'><sup></sup></span>",
			"dnd-inhibited-none": ""
		},
		"return-type": "json",
		"exec-if": "which swaync-client",
		"exec": "swaync-client -swb",
		"on-click": "swaync-client -t -sw",
		"on-click-right": "swaync-client -d -sw",
		"escape": true
	},
	"custom/separator#dot": {
		"format": "•",
		"interval": "once",
		"tooltip": false
	},
	"custom/separator#dot-line": {
		"format": "┊",
		"interval": "once",
		"tooltip": false
	},
	"custom/separator#line": {
		"format": "│",
		"interval": "once",
		"tooltip": false
	},
	"custom/separator#blank": {
		"format": "  ",
		"interval": "once",
		"tooltip": false
	}
}