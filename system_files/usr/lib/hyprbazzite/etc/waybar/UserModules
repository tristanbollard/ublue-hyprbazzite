/* Waybar Modules Extras */

{
        "user/headset-battery": {
                "format": "󰠇 {}%",
                "exec": "/etc/hypr/scripts/TritonCtl.sh LogiBattery",
                "interval": 5,
                "on-click": "solaar",
                "return-type": "integer"
        },
        "user/keyboard": {
		"format": "󰌌",
		"on-click": "/etc/hypr/scripts/waybar-osk-click.sh",
		"tooltip": true,
                "tooltip-format": "On-screen keyboard\u000AClick: Open if closed, swap half if open"
	}
}
