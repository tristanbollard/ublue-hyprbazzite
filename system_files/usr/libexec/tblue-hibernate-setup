#!/usr/bin/env bash
set -euo pipefail

SWAP_SUBVOL_PATH="/var/swap"
SWAPFILE_PATH="/var/swap/swapfile"

log() {
    echo "[tblue-hibernate-setup] $*" >&2
}

mark_done() {
    mkdir -p /var/lib/tblue
    touch /var/lib/tblue/hibernate-setup.done
}

find_swap_device() {
    local target

    target=$(swapon --noheadings --raw --output NAME,TYPE 2>/dev/null | awk '$2 != "zram" {print $1; exit}')
    if [[ -n "$target" ]]; then
        echo "$target"
        return 0
    fi

    target=$(blkid -t TYPE=swap -o device 2>/dev/null | head -n1 || true)
    if [[ -n "$target" ]]; then
        echo "$target"
        return 0
    fi

    return 1
}

ensure_swapfile_fstab_entry() {
    if grep -Eq '^[[:space:]]*/var/swap/swapfile[[:space:]]+none[[:space:]]+swap([[:space:],]|$)' /etc/fstab 2>/dev/null; then
        return 0
    fi

    printf '%s\n' '/var/swap/swapfile none swap defaults,nofail 0 0' >> /etc/fstab
}

ensure_swap_selinux_context() {
    if ! command -v semanage >/dev/null 2>&1; then
        return 0
    fi

    # Ensure the swapfile always has the correct SELinux context for hibernation
    semanage fcontext -a -t swapfile_t "$SWAPFILE_PATH" 2>/dev/null || true
    restorecon "$SWAPFILE_PATH" 2>/dev/null || true
}

disable_zram_for_hibernate() {
    mkdir -p /etc/systemd
    : > /etc/systemd/zram-generator.conf

    if swapon --noheadings --raw --output NAME 2>/dev/null | grep -q '^/dev/zram'; then
        swapoff /dev/zram0 2>/dev/null || true
    fi
}

swap_size_gib_from_ram() {
    local mem_kib mem_gib swap_gib

    mem_kib=$(awk '/MemTotal:/ {print $2; exit}' /proc/meminfo)
    mem_gib=$(( (mem_kib + 1024*1024 - 1) / (1024*1024) ))
    swap_gib="$mem_gib"

    (( swap_gib < 8 )) && swap_gib=8
    (( swap_gib > 64 )) && swap_gib=64

    echo "$swap_gib"
}

create_swapfile_if_needed() {
    local size_gib fs_type

    if swapon --noheadings --raw --output NAME 2>/dev/null | grep -qx "$SWAPFILE_PATH"; then
        ensure_swap_selinux_context
        echo "$SWAPFILE_PATH"
        return 0
    fi

    # Swapfile might exist from previous run but not be active yet; try to activate it
    if [[ -f "$SWAPFILE_PATH" ]]; then
        swapon "$SWAPFILE_PATH" >/dev/null 2>&1 || true
        ensure_swap_selinux_context
        if swapon --noheadings --raw --output NAME 2>/dev/null | grep -qx "$SWAPFILE_PATH"; then
            echo "$SWAPFILE_PATH"
            return 0
        fi
    fi

    size_gib=$(swap_size_gib_from_ram)

    if [[ ! -f "$SWAPFILE_PATH" ]]; then
        fs_type=$(findmnt -no FSTYPE -T /var 2>/dev/null || echo "")

        if [[ "$fs_type" == "btrfs" ]]; then
            if [[ ! -d "$SWAP_SUBVOL_PATH" ]]; then
                btrfs subvolume create "$SWAP_SUBVOL_PATH" >/dev/null
            fi

            if command -v btrfs >/dev/null 2>&1; then
                btrfs filesystem mkswapfile --size "${size_gib}G" "$SWAPFILE_PATH" >/dev/null
            else
                truncate -s 0 "$SWAPFILE_PATH"
                chattr +C "$SWAPFILE_PATH" 2>/dev/null || true
                fallocate -l "${size_gib}G" "$SWAPFILE_PATH"
                chmod 600 "$SWAPFILE_PATH"
                mkswap "$SWAPFILE_PATH" >/dev/null
            fi
        else
            mkdir -p "$SWAP_SUBVOL_PATH"
            fallocate -l "${size_gib}G" "$SWAPFILE_PATH"
            chmod 600 "$SWAPFILE_PATH"
            mkswap "$SWAPFILE_PATH" >/dev/null
        fi

        ensure_swap_selinux_context
        log "Created swapfile at $SWAPFILE_PATH (${size_gib}G)"
    fi

    ensure_swapfile_fstab_entry
    disable_zram_for_hibernate
    swapon "$SWAPFILE_PATH" >/dev/null 2>&1 || true

    if swapon --noheadings --raw --output NAME 2>/dev/null | grep -qx "$SWAPFILE_PATH"; then
        echo "$SWAPFILE_PATH"
        return 0
    fi

    return 1
}

swap_target_uuid() {
    local target="$1"
    local btrfs_dev btrfs_uuid luks_device luks_uuid fs_uuid

    # If swapfile is on Btrfs, get the parent FS UUID (not the LUKS UUID)
    if [[ "$(findmnt -no FSTYPE -T "$target" 2>/dev/null)" == "btrfs" ]]; then
        btrfs_dev=$(findmnt -no SOURCE -T "$target" | sed 's/\[.*//')
        btrfs_uuid=$(btrfs filesystem show "$btrfs_dev" 2>/dev/null | awk '/uuid:/ {print $2; exit}')
        if [[ -n "$btrfs_uuid" ]]; then
            log "Detected Btrfs FS UUID for swapfile: $btrfs_uuid"
            echo "$btrfs_uuid"
            return 0
        fi
    fi

    # Fallback: LUKS UUID if not Btrfs
    luks_device=$(ls /dev/mapper/luks-* 2>/dev/null | head -n1 || true)
    if [[ -n "$luks_device" ]]; then
        luks_uuid="${luks_device#/dev/mapper/luks-}"
        if blkid -U "$luks_uuid" >/dev/null 2>&1; then
            log "Detected LUKS partition UUID: $luks_uuid"
            echo "$luks_uuid"
            return 0
        fi
    fi

    # Fallback: try standard filesystem UUID detection (non-LUKS systems)
    if [[ -b "$target" ]]; then
        blkid -s UUID -o value "$target" 2>/dev/null || true
        return 0
    fi

    source=$(findmnt -no SOURCE -T "$target" 2>/dev/null || true)
    if [[ -n "$source" && -b "$source" ]]; then
        blkid -s UUID -o value "$source" 2>/dev/null || true
        return 0
    fi

    fs_uuid=$(findmnt -no UUID -T "$target" 2>/dev/null || true)
    if [[ -n "$fs_uuid" ]]; then
        echo "$fs_uuid"
        return 0
    fi

    return 1
}

resume_arg_is_valid() {
    local resume_arg="$1"
    local value

    value="${resume_arg#resume=}"
    if [[ "$value" == UUID=* ]]; then
        [[ -e "/dev/disk/by-uuid/${value#UUID=}" ]]
        return
    fi

    [[ -b "$value" ]]
}

swapfile_resume_offset() {
    local file="$1"
    local first_extent

    if command -v btrfs >/dev/null 2>&1 && [[ "$(findmnt -no FSTYPE -T "$file" 2>/dev/null || true)" == "btrfs" ]]; then
        first_extent=$(btrfs inspect-internal map-swapfile -r "$file" 2>/dev/null | head -n1 || true)
        if [[ -n "$first_extent" && "$first_extent" =~ ^[0-9]+$ ]]; then
            echo "$first_extent"
            return 0
        fi
    fi

    if ! command -v filefrag >/dev/null 2>&1; then
        return 1
    fi

    first_extent=$(filefrag -v "$file" 2>/dev/null | awk '$1 ~ /^0:/ {print $4; exit}' | sed -E 's/\.\..*$//' | tr -d ':')
    if [[ -z "$first_extent" || ! "$first_extent" =~ ^[0-9]+$ ]]; then
        return 1
    fi

    echo "$first_extent"
}

add_resume_karg_if_needed() {
    local karg="$1"
    local guard_resume=0

    [[ "$karg" == resume=* ]] && guard_resume=1

    if command -v rpm-ostree >/dev/null 2>&1; then
        local current existing_resume
        current=$(rpm-ostree kargs 2>/dev/null || true)

        if [[ $guard_resume -eq 1 ]]; then
            existing_resume=$(grep -Eo 'resume=[^[:space:]]+' <<<"$current" | head -n1 || true)
            if [[ -n "$existing_resume" && "$existing_resume" != "$karg" ]]; then
                if resume_arg_is_valid "$existing_resume"; then
                    log "Existing resume arg detected ($existing_resume); not overriding with $karg"
                    return 0
                fi

                rpm-ostree kargs --delete-if-present="$existing_resume"
                log "Removed invalid existing resume arg: $existing_resume"
            fi
        fi

        if grep -qw -- "$karg" <<<"$current"; then
            log "Kernel arg already present: $karg"
            return 0
        fi

        rpm-ostree kargs --append-if-missing="$karg"
        log "Added kernel arg via rpm-ostree: $karg"
        return 10
    fi

    if command -v grubby >/dev/null 2>&1; then
        local current existing_resume resume_value
        current=$(grubby --info=ALL 2>/dev/null | grep -Eo 'resume=[^[:space:]"]+' | head -n1 || true)

        if [[ $guard_resume -eq 1 ]]; then
            existing_resume="$current"
            if [[ -n "$existing_resume" && "$existing_resume" != "$karg" ]]; then
                if resume_arg_is_valid "$existing_resume"; then
                    log "Existing resume arg detected ($existing_resume); not overriding with $karg"
                    return 0
                fi

                resume_value="${existing_resume#resume=}"
                grubby --update-kernel=ALL --remove-args="resume=${resume_value}" >/dev/null 2>&1 || true
                log "Removed invalid existing resume arg: $existing_resume"
            fi
        fi

        if [[ "$current" == "$karg" ]]; then
            log "Kernel arg already present: $karg"
            return 0
        fi

        grubby --update-kernel=ALL --args="$karg"
        log "Added kernel arg via grubby: $karg"
        return 10
    fi

    log "No supported bootloader tool found (rpm-ostree/grubby)."
    return 1
}

cleanup_conflicting_resume_kargs() {
    local current changed=0
    local -a resume_args=()
    local -a uuid_resume_args=()
    local arg has_non_uuid=0

    if ! command -v rpm-ostree >/dev/null 2>&1; then
        return 0
    fi

    current=$(rpm-ostree kargs 2>/dev/null || true)
    while IFS= read -r arg; do
        [[ -z "$arg" ]] && continue
        resume_args+=("$arg")
        if [[ "$arg" == resume=UUID=* ]]; then
            uuid_resume_args+=("$arg")
        else
            has_non_uuid=1
        fi
    done < <(grep -Eo 'resume=[^[:space:]]+' <<<"$current" | awk '!seen[$0]++')

    if [[ ${#resume_args[@]} -lt 2 || ${#uuid_resume_args[@]} -eq 0 || $has_non_uuid -eq 0 ]]; then
        return 0
    fi

    for arg in "${uuid_resume_args[@]}"; do
        rpm-ostree kargs --delete-if-present="$arg"
        log "Removed conflicting kernel arg via rpm-ostree: $arg"
        changed=1
    done

    if [[ $changed -eq 1 ]]; then
        return 10
    fi

    return 0
}

main() {
    local swap_target swap_uuid resume_offset karg needs_reboot=0 rc=0

    rc=0
    if cleanup_conflicting_resume_kargs; then
        :
    else
        rc=$?
        if [[ $rc -eq 10 ]]; then
            needs_reboot=1
        fi
    fi

    swap_target=$(find_swap_device || true)
    if [[ -z "${swap_target:-}" ]]; then
        swap_target=$(create_swapfile_if_needed || true)
        if [[ -z "${swap_target:-}" ]]; then
            log "No non-zram swap found and swapfile creation failed; hibernate resume is not configured."
            mark_done
            exit 0
        fi
    fi

    swap_uuid=$(swap_target_uuid "$swap_target" || true)
    if [[ -z "$swap_uuid" ]]; then
        log "Could not read UUID for swap target $swap_target; skipping resume kernel arg."
        mark_done
        exit 0
    fi

    disable_zram_for_hibernate

    karg="resume=UUID=$swap_uuid"
    if add_resume_karg_if_needed "$karg"; then
        :
    else
        rc=$?
        if [[ $rc -eq 10 ]]; then
            needs_reboot=1
        fi
    fi

    if [[ -f "$swap_target" ]]; then
        resume_offset=$(swapfile_resume_offset "$swap_target" || true)
        if [[ -n "$resume_offset" ]]; then
            if add_resume_karg_if_needed "resume_offset=$resume_offset"; then
                :
            else
                rc=$?
                if [[ $rc -eq 10 ]]; then
                    needs_reboot=1
                fi
            fi
        else
            log "Could not determine resume_offset for swapfile ($swap_target); hibernate may not resume from swapfile."
        fi
    fi

    if [[ $needs_reboot -eq 1 ]]; then
        mkdir -p /var/lib/tblue
        touch /var/lib/tblue/hibernate-reboot-required
        log "Hibernate resume configured. Reboot required to apply new kernel arg."
    fi

    mark_done
    log "Completed."
}

main "$@"
