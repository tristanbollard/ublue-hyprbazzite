#!/usr/bin/env bash
set -euo pipefail

SWAP_SUBVOL_PATH="/var/swap"
SWAPFILE_PATH="/var/swap/swapfile"

log() { echo "[tblue-hibernate] $*" >&2; }

create_swap_on_var() {
    # 1. Create Subvolume if missing
    if ! btrfs subvolume show "$SWAP_SUBVOL_PATH" >/dev/null 2>&1; then
        [[ -d "$SWAP_SUBVOL_PATH" ]] && rm -rf "$SWAP_SUBVOL_PATH"
        btrfs subvolume create "$SWAP_SUBVOL_PATH"
    fi

    # 2. Create the swapfile using the Btrfs-optimized command
    if [[ ! -f "$SWAPFILE_PATH" ]]; then
        local mem_gib
        mem_gib=$(awk '/MemTotal:/ {print int($2/1024/1024 + 2)}' /proc/meminfo)
        log "Creating ${mem_gib}G swapfile..."
        btrfs filesystem mkswapfile --size "${mem_gib}G" "$SWAPFILE_PATH"
    fi

    # 3. Apply labels (The policy is in /usr, the file is on /var)
    chmod 600 "$SWAPFILE_PATH"
    restorecon -RF "$SWAP_SUBVOL_PATH"
    
    if ! swapon --show | grep -q "$SWAPFILE_PATH"; then
        mkswap "$SWAPFILE_PATH" 2>/dev/null || true
        swapon "$SWAPFILE_PATH"
    fi
}

main() {
    create_swap_on_var

    # 1. Add to fstab if missing
    if ! grep -q "$SWAPFILE_PATH" /etc/fstab; then
        echo "$SWAPFILE_PATH none swap defaults,nofail 0 0" >> /etc/fstab
    fi

    # 2. Get the decrypted device path and physical offset
    local dec_dev offset
    dec_dev=$(findmnt -no SOURCE -T "$SWAP_SUBVOL_PATH")
    offset=$(btrfs inspect-internal map-swapfile -r "$SWAPFILE_PATH" | head -n1)

    log "Targeting resume device: $dec_dev at offset: $offset"

    # 3. Apply kargs safely
    # We use --replace to overwrite any old resume/offset attempts
    # and --append-if-missing for the safety flags.
    rpm-ostree kargs \
        --replace="resume=$dec_dev" \
        --replace="resume_offset=$offset" \
        --append-if-missing="rootwait" \
        --append-if-missing="resume_delay=5"
}

main "$@"