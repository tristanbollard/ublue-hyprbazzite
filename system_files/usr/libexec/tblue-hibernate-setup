

#!/usr/bin/env bash
set -euo pipefail

SWAPFILE_PATH="/var/swap/swapfile"
log() { echo "[tblue-hybrid-sleep] $*" >&2; }

# 1. Ensure swapfile exists and is in fstab
if [[ ! -f "$SWAPFILE_PATH" ]]; then
    log "Error: swapfile $SWAPFILE_PATH does not exist. Please create it first."
    exit 1
fi
if ! grep -q "$SWAPFILE_PATH" /etc/fstab; then
    echo "$SWAPFILE_PATH none swap defaults,nofail 0 0" >> /etc/fstab
fi

# 2. Get the decrypted device path and physical offset
dec_uuid=$(findmnt -no UUID -T "$SWAPFILE_PATH")
if [[ -z "$dec_uuid" ]]; then
    log "Error: Could not determine Decrypted UUID"
    exit 1
fi
offset=$(btrfs inspect-internal map-swapfile -r "$SWAPFILE_PATH" | head -n1)
if [[ -z "$offset" ]]; then
    log "Error: Could not determine swapfile offset"
    exit 1
fi

log "Setting resume=UUID=$dec_uuid and resume_offset=$offset for hybrid sleep."

# 3. Set kernel arguments for hybrid sleep
rpm-ostree kargs \
    --replace="resume=UUID=$dec_uuid" \
    --replace="resume_offset=$offset" \
    --append-if-missing="rootwait" \
    --append-if-missing="resume_delay=5"

# 4. Enable hybrid sleep, disable hibernation
if grep -q "^AllowSuspend" /etc/systemd/sleep.conf; then
    sed -i 's/^AllowSuspend.*/AllowSuspend=yes/' /etc/systemd/sleep.conf
else
    echo "AllowSuspend=yes" >> /etc/systemd/sleep.conf
fi
if grep -q "^AllowHibernation" /etc/systemd/sleep.conf; then
    sed -i 's/^AllowHibernation.*/AllowHibernation=no/' /etc/systemd/sleep.conf
else
    echo "AllowHibernation=no" >> /etc/systemd/sleep.conf
fi
if grep -q "^AllowSuspendThenHibernate" /etc/systemd/sleep.conf; then
    sed -i 's/^AllowSuspendThenHibernate.*/AllowSuspendThenHibernate=yes/' /etc/systemd/sleep.conf
else
    echo "AllowSuspendThenHibernate=yes" >> /etc/systemd/sleep.conf
fi

log "Hybrid sleep setup complete."

# 5. Disable all wakeup sources except the power button
log "Disabling all wakeup sources except the power button."
if [[ -f /proc/acpi/wakeup ]]; then
    # Get the power button device (usually PBTN or PWRB)
    power_btns=$(awk '/PBTN|PWRB/ {print $1}' /proc/acpi/wakeup)
    # Disable all other wakeup devices
    grep enabled /proc/acpi/wakeup | awk '{print $1}' | while read dev; do
        if ! echo "$power_btns" | grep -q "$dev"; then
            echo "$dev" > /proc/acpi/wakeup
            log "Disabled wakeup for $dev"
        fi
    done
    log "Wakeup sources after filtering:"
    cat /proc/acpi/wakeup >&2
else
    log "/proc/acpi/wakeup not found; skipping wakeup source filtering."
fi